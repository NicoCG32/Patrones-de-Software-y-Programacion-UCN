@startuml
title Facade - Ejemplo 3 - solucion para conversion multimedia
left to right direction
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 8
skinparam classAttributeIconSize 0
skinparam class {
  BackgroundColor #F8FAFC
  BorderColor #334155
  ArrowColor #334155
  FontColor #0F172A
}
hide empty members

package "main" #EEF2FF {
  class Main <<cliente>>
}

package "pattern" #ECFDF5 {
  class FilterEngine {
    +apply(String filter): void
  }
  class MediaConversionFacade {
    +convert(String file, String format): void
  }
  class VideoDecoder {
    +decode(String file): void
  }
  class VideoEncoder {
    +encode(String format): void
  }
}

FilterEngine ..> VideoEncoder : crea
FilterEngine ..> VideoDecoder : crea
MediaConversionFacade ..> FilterEngine : crea
MediaConversionFacade ..> VideoEncoder : crea
MediaConversionFacade ..> VideoDecoder : crea
VideoDecoder ..> FilterEngine : crea
VideoDecoder ..> VideoEncoder : crea
Main ..> FilterEngine : ejecuta

note bottom
La implementacion esta concentrada en src/pattern/PatternImplementation.java.
Main solo instancia y ejecuta el caso de uso.
end note
@enduml
