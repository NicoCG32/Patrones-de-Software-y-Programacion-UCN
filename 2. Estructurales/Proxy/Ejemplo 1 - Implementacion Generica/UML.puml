@startuml
title Proxy - Ejemplo 1 - Implementacion Generica
skinparam classAttributeIconSize 0
hide empty fields
class "main.Main" as main_Main {
  +main(String[] args): void
}
class "pattern.Proxy" as pattern_Proxy {
  +request(): void
}
class "pattern.RealSubject" as pattern_RealSubject {
  +RealSubject()
  +request(): void
}
interface "pattern.Subject" as pattern_Subject {
}
pattern_Subject <|.. pattern_Proxy
pattern_Subject <|.. pattern_RealSubject
main_Main ..> pattern_Proxy : instancia
main_Main --> pattern_Subject : usa
pattern_Proxy ..> pattern_RealSubject : instancia
pattern_Proxy --> pattern_Subject : usa
pattern_RealSubject --> pattern_Subject : usa
@enduml
