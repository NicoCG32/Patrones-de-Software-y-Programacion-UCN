@startuml
title Adapter - Ejemplo 3 - solucion para biblioteca con unidades distintas
left to right direction
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 8
skinparam classAttributeIconSize 0
skinparam class {
  BackgroundColor #F8FAFC
  BorderColor #334155
  ArrowColor #334155
  FontColor #0F172A
}
hide empty members

package "main" #EEF2FF {
  class Main <<cliente>>
}

package "pattern" #ECFDF5 {
  interface DistanceCalculator <<interfaz>> {
  }
  class KilometerAdapter {
    +distanceInKilometers(double origin, double destination): double
  }
  class MilesLibrary {
    +distanceInMiles(double origin, double destination): double
  }
}

DistanceCalculator <|.. KilometerAdapter
Main ..> KilometerAdapter : ejecuta

note bottom
La implementacion esta concentrada en src/pattern/PatternImplementation.java.
Main solo instancia y ejecuta el caso de uso.
end note
@enduml
