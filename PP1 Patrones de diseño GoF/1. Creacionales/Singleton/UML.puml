@startuml
title Singleton - clases
class Configuration {
  -INSTANCE: Configuration
  -environment: String
  -Configuration()
  +getInstance(): Configuration
  +environment(): String
}
class Client
Client --> Configuration : getInstance()
note right of Configuration
Constructor privado.
La instancia se crea una sola vez.
end note
@enduml

@startuml
title Singleton - interaccion
participant ClientA
participant ClientB
participant Configuration
ClientA -> Configuration : getInstance()
Configuration --> ClientA : INSTANCE
ClientB -> Configuration : getInstance()
Configuration --> ClientB : misma INSTANCE
@enduml
