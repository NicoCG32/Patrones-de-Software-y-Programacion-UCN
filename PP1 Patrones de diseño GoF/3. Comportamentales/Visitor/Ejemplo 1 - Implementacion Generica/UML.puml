@startuml
title Visitor - Ejemplo 1 - Implementacion Generica
left to right direction
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 8
skinparam classAttributeIconSize 0
skinparam class {
  BackgroundColor #F8FAFC
  BorderColor #334155
  ArrowColor #334155
  FontColor #0F172A
}
hide empty members

package "main" #EEF2FF {
  class Main <<cliente>>
}

package "pattern" #ECFDF5 {
  interface Element <<interfaz>> {
  }
  class ElementA {
    +accept(Visitor visitor): void
    +value(): String
  }
  class ElementB {
    +accept(Visitor visitor): void
    +value(): String
  }
  class ReportVisitor {
    +visit(ElementA element): void
    +visit(ElementB element): void
  }
  interface Visitor <<interfaz>> {
  }
}

Element <|.. ElementA
Element <|.. ElementB
Visitor <|.. ReportVisitor
Main ..> ElementA : ejecuta

note bottom
La implementacion esta concentrada en src/pattern/PatternImplementation.java.
Main solo instancia y ejecuta el caso de uso.
end note
@enduml
