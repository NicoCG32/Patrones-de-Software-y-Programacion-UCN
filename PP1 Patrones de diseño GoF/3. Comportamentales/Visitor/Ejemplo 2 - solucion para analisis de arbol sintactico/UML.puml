@startuml
title Visitor - Ejemplo 2 - solucion para analisis de arbol sintactico
left to right direction
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 8
skinparam classAttributeIconSize 0
skinparam class {
  BackgroundColor #F8FAFC
  BorderColor #334155
  ArrowColor #334155
  FontColor #0F172A
}
hide empty members

package "main" #EEF2FF {
  class Main <<cliente>>
}

package "pattern" #ECFDF5 {
  class AddNode {
    +left(): AstNode
    +right(): AstNode
    +accept(AstVisitor visitor): void
  }
  interface AstNode <<interfaz>> {
  }
  interface AstVisitor <<interfaz>> {
  }
  class NumberNode {
    +value(): int
    +accept(AstVisitor visitor): void
  }
  class PrintVisitor {
    +visit(NumberNode node): void
    +visit(AddNode node): void
  }
}

AstNode <|.. AddNode
AstNode <|.. NumberNode
AstVisitor <|.. PrintVisitor
Main ..> AddNode : ejecuta

note bottom
La implementacion esta concentrada en src/pattern/PatternImplementation.java.
Main solo instancia y ejecuta el caso de uso.
end note
@enduml
