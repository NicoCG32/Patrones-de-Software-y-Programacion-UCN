@startuml
title Strategy - Ejemplo 3 - solucion para calculo de rutas
left to right direction
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 8
skinparam classAttributeIconSize 0
skinparam class {
  BackgroundColor #F8FAFC
  BorderColor #334155
  ArrowColor #334155
  FontColor #0F172A
}
hide empty members

package "main" #EEF2FF {
  class Main <<cliente>>
}

package "pattern" #ECFDF5 {
  class CheapestRoute {
    +calculate(String origin, String destination): String
  }
  class FastestRoute {
    +calculate(String origin, String destination): String
  }
  class Navigator {
    +setStrategy(RouteStrategy strategy): void
    +navigate(String origin, String destination): void
  }
  interface RouteStrategy <<interfaz>> {
  }
}

RouteStrategy <|.. CheapestRoute
RouteStrategy <|.. FastestRoute
Main ..> CheapestRoute : ejecuta

note bottom
La implementacion esta concentrada en src/pattern/PatternImplementation.java.
Main solo instancia y ejecuta el caso de uso.
end note
@enduml
