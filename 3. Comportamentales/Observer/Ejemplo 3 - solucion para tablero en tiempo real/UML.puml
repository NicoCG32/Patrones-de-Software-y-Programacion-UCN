@startuml
title Observer - Ejemplo 3 - solucion para tablero en tiempo real
left to right direction
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 8
skinparam classAttributeIconSize 0
skinparam class {
  BackgroundColor #F8FAFC
  BorderColor #334155
  ArrowColor #334155
  FontColor #0F172A
}
hide empty members

package "main" #EEF2FF {
  class Main <<cliente>>
}

package "pattern" #ECFDF5 {
  class ChartWidget {
    +update(int activeUsers): void
  }
  class CounterWidget {
    +update(int activeUsers): void
  }
  interface MetricObserver <<interfaz>> {
  }
  class RealtimeDashboard {
    +attach(MetricObserver observer): void
    +setActiveUsers(int activeUsers): void
  }
}

MetricObserver <|.. ChartWidget
MetricObserver <|.. CounterWidget
Main ..> ChartWidget : ejecuta

note bottom
La implementacion esta concentrada en src/pattern/PatternImplementation.java.
Main solo instancia y ejecuta el caso de uso.
end note
@enduml
